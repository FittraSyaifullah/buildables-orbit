{
  "name": "buildables-orbit",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n client,server -c cyan,magenta \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite",
    "dev:server": "node server/index.js",
    "build": "vite build",
    "start": "cross-env NODE_ENV=production node server/index.js",
    "prod:local": "npm run build && cross-env NODE_ENV=production node server/index.js",
    "preview": "vite preview",
    "docker:build": "docker build -t buildables-orbit .",
    "docker:run": "docker compose up --build"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "three": "^0.185.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "vite": "^6.2.0"
  }
}
